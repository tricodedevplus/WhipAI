# Anthropic API key — required for any skill invocation to work.
# Without this, the server starts but returns 503 for /skill/*/invoke.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Default model used by skills when they don't pin their own.
# Per skill guidance, default to Opus 4.7. Override per-skill in the skill class.
DEFAULT_MODEL=claude-opus-4-7

# Shared secret between WhipBridge and WhipAI. WhipBridge sends this on
# every call as the `x-api-key` header. Generate a strong random value
# (e.g. `openssl rand -hex 32`) and set THE SAME value on WhipBridge's
# WHIPAI_API_KEY env var.
#
# Without this, the server starts but returns 503 on every request —
# fail-closed so a misconfigured deploy can't accidentally accept
# unauthenticated calls.
WHIPAI_API_KEY=generate-me-openssl-rand-hex-32

# MySQL — same DB as WhipBridge (fleet_migration)
CNDW=server=...;user=...;password=...;database=fleet_migration;
CNDW_QA=server=...;user=...;password=...;database=fleet_migration;

# Optional — log level for AnthropicService / Skill invocations.
# Values: Trace, Debug, Information, Warning, Error, Critical
LOG_LEVEL=Information

# Optional — fail-open vs fail-closed when Anthropic API is down.
# true  → return 503 and let WhipBridge fall back to its hard-coded renderer
# false → retry aggressively (not recommended for user-facing skills)
AI_FAIL_OPEN=true
